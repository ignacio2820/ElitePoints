# Firebase Web SDK (cliente)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (servidor)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Una línea con \n literales (barra + n) entre bloques PEM — típico en Vercel.
# El servidor normaliza \n, \\n y comillas envolventes automáticamente.
FIREBASE_ADMIN_PRIVATE_KEY=

# Resend (email transaccional)
RESEND_API_KEY=
RESEND_FROM="Huellitas <hola@huellitas.app>"

# Cron protection
CRON_SECRET=

# URL pública de la app (subdominio en Hostinger, sin barra final).
# Usada en magic links, emails y enlaces absolutos. Configurarla antes del build.
NEXT_PUBLIC_APP_URL=https://tu-subdominio.tudominio.com

# Hosting Node.js (Hostinger u otro reverse proxy)
HOSTNAME=0.0.0.0
PORT=3000
# Salida standalone para despliegue con menos archivos (omitir o NEXT_OUTPUT=default para next start clásico)
NEXT_OUTPUT=standalone